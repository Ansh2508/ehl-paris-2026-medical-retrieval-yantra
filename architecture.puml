@startuml Non-ML MRI Retrieval Pipeline

title v33: Non-ML Cross-Modal Brain MRI Retrieval (MRR 0.928)

skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle
skinparam shadowing false

package "Preprocessing" {
    [Load NIfTI] as load
    [Foreground Mask] as mask
    [Robust Scale\n(1st-99th percentile)] as scale
    [Brain BBox Crop] as crop
    [Resize to 48^3] as resize
}

package "Registration (d2/d3 only)" {
    [SimpleITK\nAffine + Mattes MI] as reg
    [d1 Train Query\nas Reference] as ref
}

package "Feature Extraction" {
    [SSC-12 Descriptor\n(GPU, 12-edge)] as ssc
    [Mutual Information\n(d1 only)] as mi
    [3D Power Spectrum\n(FFT, 16 radial)] as fft
    [Brain Shape\nFingerprint] as bf
    [Gradient\nMagnitude] as grad
    [Intensity\nHistogram] as hist
    [3D Projections] as proj
}

package "Distance Computation" {
    [Normalize to [0,1]] as norm
    [Weighted Sum\n(per-dataset weights)] as weighted
}

package "Assignment" {
    [Hungarian Algorithm\n(scipy.optimize)] as hungarian
}

package "Output" {
    [377-row CSV] as csv
}

load --> mask
mask --> scale
scale --> crop
crop --> resize
resize --> reg : d2/d3 only
ref --> reg
reg --> ssc
resize --> ssc : d1 (no reg)
resize --> mi : d1 only
resize --> fft
resize --> bf
resize --> grad
resize --> hist
resize --> proj

ssc --> norm
mi --> norm
fft --> norm
bf --> norm
grad --> norm
hist --> norm
proj --> norm

norm --> weighted
weighted --> hungarian
hungarian --> csv

note right of ssc : Dominant feature\nweight=0.50 for d2/d3
note right of mi : Honest: only d1\n(common grid)
note right of norm : Key innovation:\nscale calibration
note right of hungarian : Exact 1-to-1\nbijection assignment

@enduml
